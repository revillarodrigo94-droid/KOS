# KITCHENOS - VARIABLES DE ENTORNO LOCALES
# Copiar este archivo como '.env' en la raíz del proyecto y rellenar con las credenciales del panel de Supabase

# URL del proyecto de Supabase (Settings > API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase (Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase
